/* ============================================================
   NeuralGraph — main.css
   Complete stylesheet: layout, 3D canvas, chat panel, modals
   ============================================================ */

/* ── Design tokens ─────────────────────────────────────────── */
:root {
  --bg:          #000000;
  --bg-panel:    #08080f;
  --bg-elevated: #0d0d1a;
  --bg-hover:    #111120;
  --border:      #1a1a2e;
  --text:        #e2e2f0;
  --text-muted:  #444466;
  --text-dim:    #333355;
  --accent:      #4f8ef7;
  --accent-glow: rgba(79,142,247,0.08);
  --danger:      #f74f6a;
  --success:     #4ff7a0;
  --font:        "IBM Plex Mono", monospace;
  --radius:      8px;
}

/* ── Reset ─────────────────────────────────────────────────── */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

html, body {
  height: 100%;
  overflow: hidden;
  background: var(--bg);
  color: var(--text);
  font-family: var(--font);
  font-size: 12px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* ── Scrollbars ─────────────────────────────────────────────── */
::-webkit-scrollbar            { width: 3px; height: 3px; }
::-webkit-scrollbar-track      { background: transparent; }
::-webkit-scrollbar-thumb      { background: var(--border); border-radius: 99px; }
::-webkit-scrollbar-thumb:hover{ background: #2a2a4a; }

/* ============================================================
   APP SHELL
   ============================================================ */
#app {
  display: flex;
  flex-direction: column;
  height: 100vh;
  width: 100vw;
  background: var(--bg);
}

/* API-key banner (injected by settings_panel.js) sits here */
#ng-api-banner {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 16px;
  background: rgba(247,160,79,0.08);
  border-bottom: 1px solid rgba(247,160,79,0.25);
  font-size: 11px;
  color: #f7a04f;
  z-index: 500;
  flex-shrink: 0;
}
.ng-banner-text  { flex: 1; }
.ng-banner-cta   {
  font-family: var(--font); font-size: 10px; font-weight: 600;
  letter-spacing: .08em; text-transform: uppercase; padding: 4px 12px;
  background: transparent; border: 1px solid #f7a04f; border-radius: 4px;
  color: #f7a04f; cursor: pointer; transition: background 150ms;
}
.ng-banner-cta:hover { background: rgba(247,160,79,0.12); }
.ng-banner-dismiss {
  background: transparent; border: none; color: #f7a04f;
  font-size: 16px; cursor: pointer; padding: 0 4px; line-height: 1;
  font-family: var(--font);
}

#main {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* ============================================================
   GRAPH AREA  (75 %)
   ============================================================ */
#graph-area {
  position: relative;
  flex: 0 0 75%;
  height: 100%;
  background: var(--bg);
  overflow: hidden;
}

#graph-canvas {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
  cursor: crosshair;
}

#graph-canvas canvas {
  display: block;
  width: 100% !important;
  height: 100% !important;
}

/* ── Node label overlay ─────────────────────────────────────── */
#label-container {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}

.node-label {
  position: absolute;
  font-family: var(--font);
  font-size: 11px;
  color: #ffffff;
  background: rgba(0,0,0,0.75);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 4px;
  padding: 2px 8px;
  pointer-events: none;
  opacity: 0;
  transition: opacity 200ms ease;
  white-space: nowrap;
  letter-spacing: 0.05em;
  transform: translateX(-50%);
  will-change: opacity, transform;
}
.node-label.visible { opacity: 1; }

/* ── Node inspector overlay ─────────────────────────────────── */
#node-inspector-overlay {
  position: absolute;
  bottom: 20px;
  left: 16px;
  width: 260px;
  max-height: 420px;
  background: rgba(8,8,15,0.94);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  overflow-y: auto;
  opacity: 0;
  transform: translateY(8px);
  pointer-events: none;
  transition: opacity 200ms ease, transform 200ms ease;
  z-index: 50;
}
#node-inspector-overlay.visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}
#node-detail { padding: 14px 16px; }

/* Hidden compat elements */
#stat-nodes, #stat-edges, #stat-updated { display: none; }

/* ============================================================
   CHAT PANEL  (25 %)
   ============================================================ */
#chat-panel {
  flex: 0 0 25%;
  height: 100%;
  background: var(--bg-panel);
  border-left: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  font-family: var(--font);
  overflow: hidden;
}

/* ── Header ─────────────────────────────────────────────────── */
#chat-header {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.chat-header-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.chat-brand {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text);
}
.chat-stats {
  font-size: 10px;
  color: var(--text-muted);
  letter-spacing: 0.05em;
}
.chat-icon-btn {
  width: 28px; height: 28px;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text-muted);
  cursor: pointer;
  display: grid;
  place-items: center;
  transition: border-color 150ms, color 150ms;
  flex-shrink: 0;
  padding: 0;
}
.chat-icon-btn:hover { border-color: var(--accent); color: var(--text); }
.chat-icon-btn svg  { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2; }
.chat-icon-btn i    { display: flex; align-items: center; justify-content: center; }

/* ── Mode toggle ─────────────────────────────────────────────── */
#chat-mode-bar {
  display: flex;
  gap: 6px;
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.mode-pill {
  flex: 1;
  font-family: var(--font);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 6px 8px;
  background: transparent;
  border: 1px solid transparent;
  border-radius: 6px;
  color: var(--text-muted);
  cursor: pointer;
  transition: background 150ms, border-color 150ms, color 150ms;
  text-align: center;
}
.mode-pill.active {
  background: #1a1a3a;
  border-color: var(--accent);
  color: var(--accent);
}
.mode-pill:not(.active):hover {
  background: var(--bg-elevated);
  color: var(--text);
}

/* ── Message feed ────────────────────────────────────────────── */
#chat-feed {
  flex: 1;
  overflow-y: auto;
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  min-height: 0;
}

.chat-msg {
  font-size: 12px;
  line-height: 1.65;
  word-break: break-word;
  animation: msg-in 180ms ease-out both;
}
@keyframes msg-in {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.chat-msg--user {
  align-self: flex-end;
  max-width: 88%;
  background: var(--bg-elevated);
  border: 1px solid #1a1a3a;
  border-radius: 8px 8px 2px 8px;
  padding: 8px 12px;
  color: var(--text);
}
.chat-msg--ai {
  align-self: flex-start;
  max-width: 96%;
  color: #c8c8e8;
  padding: 2px 0;
}
.chat-msg--system {
  align-self: center;
  font-size: 10px;
  color: var(--text-dim);
  padding: 4px 0;
  font-style: italic;
  letter-spacing: 0.04em;
}
.chat-msg--thinking {
  align-self: flex-start;
  font-size: 10px;
  color: var(--text-muted);
  letter-spacing: 0.04em;
  animation: pulse-text 1.5s ease-in-out infinite;
}
@keyframes pulse-text {
  0%,100% { opacity: 0.5; }
  50%      { opacity: 1;   }
}
.chat-msg--error { color: var(--danger); }

/* ── Source cards ────────────────────────────────────────────── */
.chat-msg--sources {
  align-self: stretch;
  font-size: 10px;
  color: var(--text-dim);
  letter-spacing: 0.04em;
}
.sources-header, .sources-footer {
  color: var(--text-dim);
  padding: 2px 0;
}
.source-item {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 4px 6px;
  border-radius: 4px;
  cursor: pointer;
  transition: background 120ms;
  margin: 1px 0;
}
.source-item:hover { background: var(--bg-elevated); }
.source-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}
.source-label {
  flex: 1;
  font-size: 11px;
  color: var(--text);
  truncation-block: initial;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.source-cat { font-size: 9px; flex-shrink: 0; }

/* ── Input area ──────────────────────────────────────────────── */
#chat-input-area {
  padding: 12px 16px 16px;
  border-top: 1px solid var(--border);
  display: flex;
  gap: 8px;
  align-items: flex-end;
  flex-shrink: 0;
}
#chat-input {
  flex: 1;
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: #e0e0ff;
  font-family: var(--font);
  font-size: 12px;
  padding: 10px 14px;
  resize: none;
  min-height: 42px;
  max-height: 120px;
  outline: none;
  transition: border-color 200ms, box-shadow 200ms;
  line-height: 1.5;
}
#chat-input::placeholder { color: var(--text-dim); }
#chat-input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-glow);
}
#chat-send {
  width: 42px; height: 42px;
  background: var(--accent);
  border: none;
  border-radius: var(--radius);
  cursor: pointer;
  display: grid;
  place-items: center;
  flex-shrink: 0;
  transition: background 150ms, transform 100ms, opacity 150ms;
  padding: 0;
}
#chat-send svg { width: 18px; height: 18px; stroke: #000; fill: none; stroke-width: 2.5; }
#chat-send i   { display: flex; align-items: center; justify-content: center; color: #000; }
#chat-send:hover  { background: #6aa3ff; }
#chat-send:active { transform: scale(0.93); }
#chat-send:disabled { opacity: 0.4; cursor: not-allowed; }

/* ============================================================
   UPLOAD MODAL
   ============================================================ */
.modal-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.8);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 200ms ease, visibility 200ms ease;
}
.modal-backdrop.active { opacity: 1; visibility: visible; }

.modal {
  width: 480px;
  max-width: 90vw;
  background: var(--bg-panel);
  border: 1px solid var(--border);
  border-radius: 10px;
  transform: translateY(10px);
  transition: transform 200ms ease;
}
.modal-backdrop.active .modal { transform: translateY(0); }

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
}
.modal-title {
  font-size: 10px; font-weight: 500; letter-spacing: .15em;
  text-transform: uppercase; color: var(--text);
}
.modal-close {
  font-family: var(--font); font-size: 14px; background: transparent;
  border: none; color: var(--text-muted); cursor: pointer;
  padding: 4px; line-height: 1; transition: color 150ms;
}
.modal-close:hover { color: var(--text); }

.modal-body {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.drop-zone {
  border: 1px dashed #2a2a44;
  border-radius: var(--radius);
  padding: 32px 24px;
  text-align: center;
  cursor: pointer;
  transition: border-color 150ms, background 150ms;
}
.drop-zone:hover, .drop-zone.dragover {
  border-color: var(--accent);
  background: var(--accent-glow);
}
.drop-zone-icon  { font-size: 16px; color: var(--text-muted); margin-bottom: 8px; }
.drop-zone-text  { font-size: 11px; color: var(--text-muted); margin-bottom: 4px; }
.drop-zone-hint  { font-size: 10px; color: var(--text-dim); }

.paste-area-label {
  font-size: 10px; letter-spacing: .15em;
  text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px;
}
.paste-area {
  font-family: var(--font); font-size: 11px; width: 100%;
  min-height: 80px; padding: 12px; background: var(--bg);
  border: 1px solid var(--border); border-radius: var(--radius);
  color: var(--text); resize: vertical; outline: none;
  transition: border-color 150ms;
}
.paste-area::placeholder { color: var(--text-dim); }
.paste-area:focus { border-color: var(--accent); }

.modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  padding: 16px 20px;
  border-top: 1px solid var(--border);
}
.modal-btn {
  font-family: var(--font); font-size: 10px; font-weight: 500;
  letter-spacing: .1em; text-transform: uppercase;
  padding: 8px 16px; border-radius: 6px;
  cursor: pointer; transition: background 150ms, opacity 150ms;
}
.modal-btn--cancel {
  background: transparent; border: 1px solid var(--border); color: var(--text-muted);
}
.modal-btn--cancel:hover { background: var(--bg-hover); color: var(--text); }
.modal-btn--primary {
  background: var(--accent); border: 1px solid var(--accent);
  color: #000; font-weight: 600;
}
.modal-btn--primary:hover { opacity: 0.85; }

/* ============================================================
   SETTINGS PANEL  override for new layout (no topbar)
   ============================================================ */
.settings-panel, #settings-panel {
  position: fixed !important;
  top: 0 !important;
  right: 0 !important;
  width: 25% !important;
  height: 100% !important;
  background: var(--bg-panel);
  border-left: 1px solid var(--border);
  z-index: 600;
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 250ms cubic-bezier(.25,.46,.45,.94);
  overflow: hidden;
}
.settings-panel.active, #settings-panel.active {
  transform: translateX(0) !important;
}

/* ============================================================
   GLOBAL BUTTON RESET
   ============================================================ */
button { font-family: var(--font); }
